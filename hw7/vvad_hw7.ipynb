# функции предсказания и расчета mse

def predict_text(text, model):
    model.eval()

    tokens = [token for token in simple_tokenize(text) if token not in stop_words][:MAX_LEN]
    indices = vocab.tokens_to_indices(tokens)
    x = torch.LongTensor(indices).unsqueeze(0).to(device)

    with torch.no_grad():
        pred_scaled = model(x).squeeze().item()

    pred_real = scaler.inverse_transform([[pred_scaled]])[0][0]
    return pred_real

def calc_valid_mse(model):
    _, valid_mse_scaled = evaluate(model, valid_loader, criterion)
    valid_mse_raw = valid_mse_scaled / (scaler.scale_[0] ** 2)
    return valid_mse_raw

